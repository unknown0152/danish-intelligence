{
    "minVersion": "0.9.0",
    "services": {
        "{ServiceName}": {
            "image": "ghcr.io/unknown0152/danish-intelligence:latest",
            "container_name": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "PROWLARR_URL=http://prowlarr:9696",
                "PROWLARR_API_KEY={{ProwlarrApiKey}}",
                "OB_API_TOKEN={{OldBoysApiToken}}",
                "OB_RID={{OldBoysRssKey}}",
                "CACHE_DB=/config/proxy_cache.db",
                "OB_PROXY_DB=/config/ob_meta.db",
                "LISTEN_PORT=9699",
                "LISTEN_HOST=0.0.0.0"
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "false",
                "cosmos-icon": "https://raw.githubusercontent.com/unknown0152/danish-intelligence/master/icon.png"
            },
            "volumes": [
                {
                    "source": "/srv/config/danish-intelligence",
                    "target": "/config",
                    "type": "bind"
                }
            ],
            "networks": {
                "media-stack": {}
            }
        }
    }
}
