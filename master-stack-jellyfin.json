{
    "minVersion": "0.9.0",
    "cosmos-installer": {
        "form": [
            {
                "name": "ProwlarrKey",
                "label": "Prowlarr API Key (optional)",
                "type": "text",
                "required": false
            },
            {
                "name": "OldBoysToken",
                "label": "OldBoys API Token (optional)",
                "type": "text",
                "required": false
            },
            {
                "name": "OldBoysRSS",
                "label": "OldBoys RSS Key / RID (optional)",
                "type": "text",
                "required": false
            },
            {
                "name": "MediaRoot",
                "label": "Host Media Root Path",
                "initialValue": "/srv/media",
                "type": "text",
                "required": true
            },
            {
                "name": "ConfigRoot",
                "label": "Host Config Root Path",
                "initialValue": "/srv/config",
                "type": "text",
                "required": true
            },
            {
                "name": "PUID",
                "label": "Container User ID (PUID)",
                "initialValue": "1001",
                "type": "text",
                "required": true
            },
            {
                "name": "PGID",
                "label": "Container Group ID (PGID)",
                "initialValue": "1001",
                "type": "text",
                "required": true
            }
        ]
    },
    "services": {
        "danish-intelligence": {
            "image": "ghcr.io/unknown0152/danish-intelligence:latest",
            "container_name": "danish-intelligence",
            "restart": "unless-stopped",
            "environment": [
                "PROWLARR_URL=http://prowlarr:9696",
                "PROWLARR_API_KEY={Context.ProwlarrKey}",
                "OB_API_TOKEN={Context.OldBoysToken}",
                "OB_RID={Context.OldBoysRSS}",
                "PROXY_API_KEY={Passwords.32}",
                "ALTMOUNT_API_KEY={Passwords.32}",
                "PUID={Context.PUID}",
                "PGID={Context.PGID}",
                "CACHE_DB=/config/proxy_cache.db",
                "OB_PROXY_DB=/config/ob_meta.db",
                "SEERR_URL=http://seerr:5055",
                "MEDIA_SERVER_TYPE=jellyfin",
                "MEDIA_SERVER_URL=http://jellyfin:8096",
                "ENABLE_2160P_ARRS=false",
                "ARR_READY_TIMEOUT_SECONDS=240",
                "ARR_READY_RETRY_SECONDS=10",
                "INSTALL_DEBUG=1",
                "INSTALL_DEBUG_FILE=/config/install-debug.jsonl",
                "INSTALL_DEBUG_SNAPSHOT=/config/install-debug-latest.json",
                "LISTEN_PORT=9699",
                "LISTEN_HOST=0.0.0.0"
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "true",
                "cosmos-icon": "https://raw.githubusercontent.com/unknown0152/danish-intelligence/master/icon.png"
            },
            "volumes": [
                {
                    "source": "{Context.ConfigRoot}/danish-intelligence",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "{Context.ConfigRoot}/prowlarr",
                    "target": "/arr-config/prowlarr",
                    "type": "bind",
                    "read_only": true
                },
                {
                    "source": "{Context.ConfigRoot}/radarr",
                    "target": "/arr-config/radarr",
                    "type": "bind",
                    "read_only": true
                },
                {
                    "source": "{Context.ConfigRoot}/sonarr",
                    "target": "/arr-config/sonarr",
                    "type": "bind",
                    "read_only": true
                },
                {
                    "source": "{Context.ConfigRoot}/seerr",
                    "target": "/seerr-config",
                    "type": "bind",
                    "read_only": true
                },
                {
                    "source": "{Context.MediaRoot}",
                    "target": "/media",
                    "type": "bind"
                }
            ],
            "networks": {
                "media-stack": {}
            }
        },
        "altmount": {
            "image": "ghcr.io/unknown0152/altmount-patched:latest",
            "container_name": "altmount",
            "restart": "unless-stopped",
            "environment": [
                "PUID={Context.PUID}",
                "PGID={Context.PGID}",
                "TZ=Europe/Copenhagen",
                "PORT=8080",
                "LOG_LEVEL=warn",
                "JWT_SECRET={Passwords.64}",
                "ALTMOUNT_AUTH_LOGIN_REQUIRED=false",
                "ALTMOUNT_API_KEY_OVERRIDE={Passwords.32}",
                "ALTMOUNT_MOUNT_TYPE=fuse",
                "ALTMOUNT_MOUNT_PATH=/mnt/altmount",
                "ALTMOUNT_FUSE_ENABLED=true",
                "ALTMOUNT_FUSE_MOUNT_PATH=/mnt/altmount",
                "ALTMOUNT_SABNZBD_COMPLETE_DIR=/complete",
                "ALTMOUNT_ENABLE_SABNZBD=true",
                "ALTMOUNT_ENABLE_ARRS=true",
                "ALTMOUNT_METADATA_ROOT_PATH=/config/metadata",
                "ALTMOUNT_METADATA_DELETE_SOURCE_NZB_ON_REMOVAL=false",
                "ALTMOUNT_METADATA_BACKUP_ENABLED=false",
                "ALTMOUNT_METADATA_BACKUP_PATH=/config/backups",
                "ALTMOUNT_METADATA_BACKUP_SCHEDULE=0 3 * * *",
                "ALTMOUNT_METADATA_BACKUP_KEEP_BACKUPS=10",
                "ALTMOUNT_SABNZBD_CATEGORIES=movies|1|0|movies|radarr;tv|2|0|tv|sonarr;movies-2160p|3|0|movies-2160p|radarr;tv-2160p|4|0|tv-2160p|sonarr;music|5|0|music|;books|6|0|books|;adult|7|0|adult|",
                "ALTMOUNT_SABNZBD_DOWNLOAD_CLIENT_BASE_URL=http://altmount:8080/sabnzbd",
                "ALTMOUNT_SABNZBD_HISTORY_RETENTION_MINUTES=10080",
                "ALTMOUNT_STREAMING_MAX_PREFETCH=60",
                "ALTMOUNT_STREAMING_FAILURE_MASKING_ENABLED=false",
                "ALTMOUNT_STREAMING_FAILURE_MASKING_THRESHOLD=3",
                "ALTMOUNT_IMPORT_MAX_PROCESSOR_WORKERS=2",
                "ALTMOUNT_IMPORT_QUEUE_PROCESSING_INTERVAL_SECONDS=5",
                "ALTMOUNT_IMPORT_MAX_IMPORT_CONNECTIONS=5",
                "ALTMOUNT_IMPORT_MAX_CONCURRENT_IMPORTS=2",
                "ALTMOUNT_IMPORT_MAX_CONCURRENT_IMPORTS_WHILE_STREAMING=1",
                "ALTMOUNT_IMPORT_ALLOWED_FILE_EXTENSIONS=.mkv,.mp4,.avi,.ts,.m4v,.mov,.wmv,.mpg,.mpeg,.xvid,.rm,.rmvb,.asf,.asx,.wtv,.mk3d,.dvr-ms",
                "ALTMOUNT_IMPORT_MAX_DOWNLOAD_PREFETCH=10",
                "ALTMOUNT_IMPORT_STRATEGY=NONE",
                "ALTMOUNT_IMPORT_WATCH_INTERVAL_SECONDS=10",
                "ALTMOUNT_IMPORT_ALLOW_NESTED_RAR_EXTRACTION=true",
                "ALTMOUNT_IMPORT_EXPAND_BLURAY_ISO=true",
                "ALTMOUNT_IMPORT_RENAME_TO_NZB_NAME=true",
                "ALTMOUNT_IMPORT_FILTER_SAMPLE_FILES=true",
                "ALTMOUNT_IMPORT_FAILED_ITEM_RETENTION_HOURS=24",
                "ALTMOUNT_IMPORT_HISTORY_RETENTION_DAYS=30",
                "ALTMOUNT_IMPORT_DELETE_COMPLETED_NZB=false",
                "ALTMOUNT_ENABLE_HEALTH=true",
                "ALTMOUNT_HEALTH_CLEANUP_ORPHANED_METADATA=false",
                "ALTMOUNT_HEALTH_CHECK_INTERVAL_SECONDS=5",
                "ALTMOUNT_HEALTH_MAX_CONCURRENT_JOBS=1",
                "ALTMOUNT_HEALTH_REPAIR_ENABLED=false",
                "ALTMOUNT_HEALTH_RESOLVE_REPAIR_ON_IMPORT=false",
                "ALTMOUNT_HEALTH_MAX_RETRIES=2",
                "ALTMOUNT_HEALTH_SEGMENT_SAMPLE_PERCENTAGE=1",
                "ALTMOUNT_HEALTH_LIBRARY_SYNC_INTERVAL_MINUTES=1440",
                "ALTMOUNT_HEALTH_MAX_REPAIR_RETRIES=3",
                "ALTMOUNT_SEGMENT_CACHE_ENABLED=true",
                "ALTMOUNT_SEGMENT_CACHE_PATH=/config/segment-cache",
                "ALTMOUNT_SEGMENT_CACHE_MAX_SIZE_GB=150",
                "ALTMOUNT_SEGMENT_CACHE_EXPIRY_HOURS=72",
                "ALTMOUNT_ARRS_QUEUE_CLEANUP_ENABLED=true",
                "ALTMOUNT_ARRS_MAX_WORKERS=5",
                "ALTMOUNT_ARRS_WEBHOOK_BASE_URL=http://altmount:8080",
                "ALTMOUNT_ARRS_CLEANUP_AUTOMATIC_IMPORT_FAILURE=false",
                "ALTMOUNT_ARRS_QUEUE_CLEANUP_INTERVAL_SECONDS=300",
                "ALTMOUNT_ARRS_QUEUE_CLEANUP_GRACE_PERIOD_MINUTES=10"
            ],
            "volumes": [
                {
                    "source": "{Context.ConfigRoot}/altmount",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "{Context.MediaRoot}",
                    "target": "/media",
                    "type": "bind"
                },
                {
                    "source": "/mnt",
                    "target": "/mnt",
                    "type": "bind",
                    "bind": {
                        "propagation": "rshared"
                    },
                    "BindOptions": {
                        "Propagation": "rshared"
                    }
                }
            ],
            "devices": [
                "/dev/fuse:/dev/fuse:rwm"
            ],
            "cap_add": [
                "SYS_ADMIN"
            ],
            "security_opt": [
                "apparmor=unconfined"
            ],
            "networks": {
                "media-stack": {}
            }
        },
        "jellyfin": {
            "image": "lscr.io/linuxserver/jellyfin:latest",
            "container_name": "jellyfin",
            "restart": "unless-stopped",
            "environment": [
                "PUID={Context.PUID}",
                "PGID={Context.PGID}",
                "TZ=Europe/Copenhagen"
            ],
            "volumes": [
                {
                    "source": "{Context.ConfigRoot}/jellyfin",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "{Context.MediaRoot}",
                    "target": "/media",
                    "type": "bind"
                },
                {
                    "source": "/mnt",
                    "target": "/mnt",
                    "type": "bind",
                    "bind": {
                        "propagation": "rshared"
                    },
                    "BindOptions": {
                        "Propagation": "rshared"
                    }
                }
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "true",
                "cosmos-icon": "https://raw.githubusercontent.com/jellyfin/jellyfin-web/master/src/assets/img/icon-transparent.png"
            },
            "networks": {
                "media-stack": {}
            }
        },
        "seerr": {
            "image": "ghcr.io/seerr-team/seerr:latest",
            "container_name": "seerr",
            "init": true,
            "user": "{Context.PUID}:{Context.PGID}",
            "restart": "unless-stopped",
            "environment": [
                "PORT=5055",
                "LOG_LEVEL=info",
                "TZ=Europe/Copenhagen"
            ],
            "volumes": [
                {
                    "source": "{Context.ConfigRoot}/seerr",
                    "target": "/app/config",
                    "type": "bind"
                }
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "true",
                "cosmos-icon": "https://raw.githubusercontent.com/seerr-team/seerr/develop/public/android-chrome-512x512.png"
            },
            "networks": {
                "media-stack": {}
            }
        },
        "radarr": {
            "image": "lscr.io/linuxserver/radarr:latest",
            "container_name": "radarr",
            "restart": "unless-stopped",
            "environment": [
                "PUID={Context.PUID}",
                "PGID={Context.PGID}",
                "TZ=Europe/Copenhagen"
            ],
            "volumes": [
                {
                    "source": "{Context.ConfigRoot}/radarr",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "{Context.MediaRoot}",
                    "target": "/media",
                    "type": "bind"
                },
                {
                    "source": "/mnt",
                    "target": "/mnt",
                    "type": "bind",
                    "bind": {
                        "propagation": "rshared"
                    },
                    "BindOptions": {
                        "Propagation": "rshared"
                    }
                }
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "true"
            },
            "networks": {
                "media-stack": {}
            }
        },
        "sonarr": {
            "image": "lscr.io/linuxserver/sonarr:latest",
            "container_name": "sonarr",
            "restart": "unless-stopped",
            "environment": [
                "PUID={Context.PUID}",
                "PGID={Context.PGID}",
                "TZ=Europe/Copenhagen"
            ],
            "volumes": [
                {
                    "source": "{Context.ConfigRoot}/sonarr",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "{Context.MediaRoot}",
                    "target": "/media",
                    "type": "bind"
                },
                {
                    "source": "/mnt",
                    "target": "/mnt",
                    "type": "bind",
                    "bind": {
                        "propagation": "rshared"
                    },
                    "BindOptions": {
                        "Propagation": "rshared"
                    }
                }
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "true"
            },
            "networks": {
                "media-stack": {}
            }
        }
    },
    "networks": {
        "media-stack": {
            "name": "media-stack",
            "driver": "bridge",
            "attachable": true
        }
    }
}
