{
    "minVersion": "0.9.0",
    "cosmos-installer": {
        "form": [
            {
                "name": "MediaRoot",
                "label": "Host Media Root Path",
                "initialValue": "/srv/media",
                "type": "text",
                "required": true
            },
            {
                "name": "JWTSecret",
                "label": "JWT Secret (Random string)",
                "initialValue": "{Passwords.32}",
                "type": "text",
                "required": true
            }
        ]
    },
    "services": {
        "{ServiceName}": {
            "image": "ghcr.io/unknown0152/altmount-patched:latest",
            "container_name": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "PUID=1001",
                "PGID=1001",
                "TZ=Europe/Copenhagen",
                "PORT=8080",
                "LOG_LEVEL=warn",
                "JWT_SECRET={Context.JWTSecret}",
                "ALTMOUNT_MOUNT_PATH=/mnt/altmount",
                "ALTMOUNT_SABNZBD_COMPLETE_DIR=/complete",
                "ALTMOUNT_ENABLE_SABNZBD=true",
                "ALTMOUNT_ENABLE_ARRS=true",
                "ALTMOUNT_LOGIN_REQUIRED=true",
                "ALTMOUNT_API_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://altmount:8080",
                "ALTMOUNT_ENABLE_HEALTH=true",
                "ALTMOUNT_HEALTH_RESOLVE_REPAIR_ON_IMPORT=true",
                "ALTMOUNT_HEALTH_MAX_RETRIES=2",
                "ALTMOUNT_HEALTH_MAX_REPAIR_RETRIES=3",
                "ALTMOUNT_SEGMENT_CACHE_ENABLED=true",
                "ALTMOUNT_SEGMENT_CACHE_PATH=/config/segment-cache",
                "ALTMOUNT_SEGMENT_CACHE_MAX_SIZE_GB=50",
                "ALTMOUNT_SEGMENT_CACHE_EXPIRY_HOURS=168",
                "ALTMOUNT_ARRS_QUEUE_CLEANUP_ENABLED=true",
                "ALTMOUNT_ARRS_QUEUE_CLEANUP_INTERVAL_SECONDS=300"
            ],
            "volumes": [
                {
                    "source": "/srv/config/altmount",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "/srv/data/altmount",
                    "target": "/data",
                    "type": "bind"
                },
                {
                    "source": "{Context.MediaRoot}",
                    "target": "/media",
                    "type": "bind"
                },
                {
                    "source": "/mnt",
                    "target": "/mnt",
                    "type": "bind",
                    "bind": {
                        "propagation": "rshared"
                    }
                }
            ],
            "devices": [
                "/dev/fuse:/dev/fuse:rwm"
            ],
            "cap_add": [
                "SYS_ADMIN"
            ],
            "security_opt": [
                "apparmor:unconfined"
            ],
            "networks": {
                "media-stack": {
                    "aliases": [
                        "altmount"
                    ]
                }
            }
        }
    }
}
