{
    "cosmos-installer": {
        "form": [
            {
                "name": "Prowlarr_API_Key",
                "label": "Prowlarr API Key",
                "type": "text",
                "required": true
            },
            {
                "name": "OldBoys_API_Token",
                "label": "OldBoys API Token",
                "type": "text",
                "required": true
            },
            {
                "name": "OldBoys_RSS_Key",
                "label": "OldBoys RSS Key (RID)",
                "type": "text",
                "required": true
            }
        ]
    },
    "minVersion": "0.9.0",
    "services": {
        "{ServiceName}": {
            "image": "ghcr.io/unknown0152/danish-intelligence:latest",
            "container_name": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "PROWLARR_URL=http://prowlarr:9696",
                "PROWLARR_API_KEY={Context.Prowlarr_API_Key}",
                "OB_API_TOKEN={Context.OldBoys_API_Token}",
                "OB_RID={Context.OldBoys_RSS_Key}",
                "CACHE_DB=/config/proxy_cache.db",
                "OB_PROXY_DB=/config/ob_meta.db",
                "LISTEN_PORT=9699",
                "LISTEN_HOST=0.0.0.0"
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "false",
                "cosmos-icon": "https://raw.githubusercontent.com/unknown0152/danish-intelligence/master/icon.png"
            },
            "volumes": [
                {
                    "source": "/srv/config/danish-intelligence",
                    "target": "/config",
                    "type": "bind"
                }
            ],
            "networks": {
                "media-stack": {}
            }
        }
    }
}
