{
    "minVersion": "0.9.0",
    "cosmos-installer": {
        "form": [
            {
                "name": "ProwlarrKey",
                "label": "Prowlarr API Key (optional)",
                "type": "text",
                "required": false
            },
            {
                "name": "OldBoysToken",
                "label": "OldBoys API Token (optional)",
                "type": "text",
                "required": false
            },
            {
                "name": "OldBoysRSS",
                "label": "OldBoys RSS Key / RID (optional)",
                "type": "text",
                "required": false
            }
        ]
    },
    "services": {
        "danish-intelligence": {
            "image": "ghcr.io/unknown0152/danish-intelligence:latest",
            "container_name": "danish-intelligence",
            "restart": "unless-stopped",
            "environment": [
                "PROWLARR_URL=http://prowlarr:9696",
                "PROWLARR_API_KEY={Context.ProwlarrKey}",
                "OB_API_TOKEN={Context.OldBoysToken}",
                "OB_RID={Context.OldBoysRSS}",
                "PROXY_API_KEY={Passwords.32}",
                "PROXY_URL=http://danish-intelligence:9699",
                "ALTMOUNT_URL=http://altmount:8080/sabnzbd",
                "RADARR_URL=http://radarr:7878",
                "SONARR_URL=http://sonarr:8989",
                "CACHE_DB=/config/proxy_cache.db",
                "OB_PROXY_DB=/config/ob_meta.db",
                "INSTALL_DEBUG=1",
                "INSTALL_DEBUG_FILE=/config/install-debug.jsonl",
                "INSTALL_DEBUG_SNAPSHOT=/config/install-debug-latest.json",
                "LISTEN_PORT=9699",
                "LISTEN_HOST=0.0.0.0"
            ],
            "labels": {
                "cosmos-auto-update": "true",
                "cosmos-force-network-secured": "true",
                "cosmos-icon": "https://raw.githubusercontent.com/unknown0152/danish-intelligence/v1.0.7/icon.png"
            },
            "volumes": [
                {
                    "source": "/srv/config/danish-intelligence",
                    "target": "/config",
                    "type": "bind"
                },
                {
                    "source": "/srv/config/prowlarr",
                    "target": "/arr-config/prowlarr",
                    "type": "bind",
                    "read_only": true
                },
                {
                    "source": "/srv/config/radarr",
                    "target": "/arr-config/radarr",
                    "type": "bind",
                    "read_only": true
                },
                {
                    "source": "/srv/config/sonarr",
                    "target": "/arr-config/sonarr",
                    "type": "bind",
                    "read_only": true
                }
            ],
            "networks": {
                "media-stack": {
                    "aliases": [
                        "danish-intelligence",
                        "dksubs-proxy"
                    ]
                }
            }
        }
    },
    "networks": {
        "media-stack": {
            "name": "media-stack",
            "driver": "bridge",
            "attachable": true
        }
    }
}
